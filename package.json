{
  "name": "quantizedvision-site",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/generate-redirects.cjs",
    "preview": "astro preview",
    "astro": "astro",
    "media:prepare": "node scripts/prepare-media.mjs",
    "cms:migrate-legacy-home": "npx sanity exec scripts/migrateLegacyHomeToPage.cjs --with-user-token --working-dir ./studio",
    "cms:import-news": "npx sanity exec scripts/importAiTechNews.cjs --with-user-token --working-dir ./studio",
    "studio:dev": "npm --prefix ./studio run dev",
    "studio:build": "npm --prefix ./studio run build"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.12",
    "@astrojs/sitemap": "^3.7.0",
    "@sanity/client": "^7.16.0",
    "@sanity/image-url": "^2.0.3",
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^5.17.1",
    "sharp": "^0.34.3",
    "tailwindcss": "^4.2.1"
  }
}
