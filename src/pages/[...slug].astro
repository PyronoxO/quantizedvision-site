---
import PageSections from "../components/PageSections.astro";
import SiteLayout from "../layouts/SiteLayout.astro";
import { getArtworks, getCmsPageByPath, getPosts, getProjects, getRedirectRules } from "../lib/content";
import { setSanityRuntimeEnv } from "../lib/sanity";
import type { HomeThemeVariant, PageConfig, RedirectRule } from "../types/content";

setSanityRuntimeEnv((Astro.locals as any)?.runtime?.env);
const preview = Astro.url.searchParams.get("preview") === "1";
const rawSlug = (Astro.params.slug || "").replace(/^\/+|\/+$/g, "");
const pathname = `/${rawSlug}`;
const [page, redirects] = await Promise.all([getCmsPageByPath(pathname, { preview }), getRedirectRules({ preview })]);
const redirect = redirects.find((rule) => `/${(rule.from || "").replace(/^\/+|\/+$/g, "")}` === pathname) as RedirectRule | undefined;
const isRedirect = Boolean(redirect?.to);
const [artworks, posts, projects] = isRedirect || !page
  ? [[], [], []]
  : await Promise.all([getArtworks({ preview }), getPosts({ preview }), getProjects({ preview })]);
if (!isRedirect && !page) {
  Astro.response.status = 404;
}

const themePresets: Record<HomeThemeVariant, { section: string }> = {
  "crimson-ice": { section: "border-[#202d47] bg-[#0a1224]" },
  "obsidian-neon": { section: "border-[#1c3548] bg-[#071823]" },
  "mono-editorial": { section: "border-[#3a3a45] bg-[#101014]" },
};

const theme = page ? themePresets[page.themeVariant] || themePresets["crimson-ice"] : themePresets["crimson-ice"];
const pageSections = page && Array.isArray(page.sections) ? page.sections.filter(Boolean) : [];
const hasHeroContent = Boolean(
  page?.hero?.body?.trim() ||
  page?.hero?.eyebrow?.trim() ||
  (page?.hero?.primaryLabel && page?.hero?.primaryUrl) ||
  (page?.hero?.secondaryLabel && page?.hero?.secondaryUrl),
);
const showPageHero = hasHeroContent || pageSections.length === 0;
const isAboutPage = page?.slug === "about";
const heroParagraphs = (page?.hero?.body || "")
  .split(/\n{2,}/)
  .map((line) => line.trim())
  .filter(Boolean);
const pageHeroMedia = (page?.hero?.mediaItems || [])
  .map((item) => ({
    src: item.imageUrl?.trim() || "",
    alt: item.alt?.trim() || page?.title || "Page hero image",
  }))
  .filter((item) => Boolean(item.src));
const heroImageEdgeToEdge = page?.hero?.imageLayout === "edge-to-edge";
const publicSiteUrl = (import.meta.env.PUBLIC_SITE_URL || "").trim() || Astro.url.origin;
const pageUrl = new URL(pathname, publicSiteUrl).toString();
const pageName = page?.title || rawSlug || "Page";
const defaultMetaTitle = isRedirect ? "Redirecting..." : `${pageName} | Quantized Vision`;
const defaultMetaDescription = isRedirect
  ? "Redirecting to the updated location."
  : page?.hero?.body?.trim() || `Explore ${pageName} at Quantized Vision.`;
const legacyStudioPattern = /creative direction studio/i;
const resolvedMetaDescription = (() => {
  const seoDescription = (page?.seo?.metaDescription || "").trim();
  if (!seoDescription) return defaultMetaDescription;
  if (!legacyStudioPattern.test(seoDescription)) return seoDescription;
  return heroParagraphs[0] || defaultMetaDescription;
})();
const resolvedOgDescription = (() => {
  const seoOgDescription = (page?.seo?.ogDescription || "").trim();
  if (!seoOgDescription) return undefined;
  if (!legacyStudioPattern.test(seoOgDescription)) return seoOgDescription;
  return heroParagraphs[0] || defaultMetaDescription;
})();
const breadcrumbSchema = !isRedirect && page
  ? {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Home",
          item: `${publicSiteUrl.replace(/\/+$/, "")}/`,
        },
        {
          "@type": "ListItem",
          position: 2,
          name: page.title,
          item: pageUrl,
        },
      ],
    }
  : null;
const listSectionTypes = new Set(pageSections.map((section) => section?._type).filter(Boolean));
const hasArchiveList = listSectionTypes.has("postArchiveSection") || listSectionTypes.has("artworkArchiveSection") || listSectionTypes.has("projectArchiveSection");
const collectionSchema = !isRedirect && page && hasArchiveList
  ? {
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      name: page.title,
      url: pageUrl,
      description: resolvedMetaDescription,
      isPartOf: `${publicSiteUrl.replace(/\/+$/, "")}/`,
    }
  : null;
const aboutPageSchema = !isRedirect && page && isAboutPage
  ? {
      "@context": "https://schema.org",
      "@type": "AboutPage",
      name: page.title,
      url: pageUrl,
      description: resolvedMetaDescription,
      isPartOf: `${publicSiteUrl.replace(/\/+$/, "")}/`,
      about: {
        "@type": "Organization",
        name: "Quantized Vision",
        url: `${publicSiteUrl.replace(/\/+$/, "")}/`,
      },
    }
  : null;
---

<SiteLayout
  title={page?.seo?.metaTitle || defaultMetaTitle}
  description={resolvedMetaDescription}
  canonicalUrl={isRedirect ? undefined : page?.seo?.canonicalUrl || pageUrl}
  ogTitle={isRedirect ? undefined : page?.seo?.ogTitle}
  ogDescription={isRedirect ? undefined : resolvedOgDescription}
  ogImage={isRedirect ? undefined : page?.seo?.ogImage}
  noIndex={isRedirect ? true : Boolean(page?.seo?.noIndex)}
>
  {breadcrumbSchema ? <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} /> : null}
  {collectionSchema ? <script slot="head" type="application/ld+json" set:html={JSON.stringify(collectionSchema)} /> : null}
  {aboutPageSchema ? <script slot="head" type="application/ld+json" set:html={JSON.stringify(aboutPageSchema)} /> : null}
  {isRedirect ? (
    <section class="dynamic-template space-y-4">
      <article class="rounded-2xl border border-[#202d47] bg-[#0a1224] p-6 md:p-9">
        <h1 class="font-black uppercase tracking-[0.03em]">Redirecting...</h1>
        <p class="mt-3 qv-muted">This page moved to <a href={redirect?.to} class="qv-link underline">{redirect?.to}</a>.</p>
      </article>
      <meta http-equiv="refresh" content={`0;url=${redirect?.to}`} />
      <script is:inline>{`window.location.replace(${JSON.stringify(redirect?.to || "/")});`}</script>
    </section>
  ) : (
  <section class:list={["dynamic-template space-y-8", isAboutPage ? "qv-about-page" : ""]}>
    {!page ? (
      <article class="rounded-2xl border border-[#202d47] bg-[#0a1224] p-6 md:p-9">
        <h1 class="font-black uppercase tracking-[0.03em]">Page Not Found</h1>
        <p class="mt-3 qv-muted">This page does not exist.</p>
        <a href="/" class="qv-btn-accent mt-6 inline-flex rounded-xl px-5 py-3 text-sm font-bold uppercase tracking-[0.12em]">Back Home</a>
      </article>
    ) : (
      <>
    {showPageHero ? (
      <article class:list={[isAboutPage ? "p-2 md:p-3 md:py-6" : "qv-page-hero rounded-2xl p-6 md:p-9 md:py-12"]}>
        {page.hero?.eyebrow ? (
          <p class="qv-eyebrow inline-flex rounded-full border px-3 py-1 text-xs uppercase tracking-[0.16em]">
            {page.hero.eyebrow}
          </p>
        ) : null}
        <h1 class="qv-page-hero-title mt-4 max-w-5xl font-black uppercase">{page.hero?.title || page.title}</h1>
        {heroParagraphs.length ? (
          <div class:list={["mt-5 space-y-4", isAboutPage ? "max-w-4xl" : "max-w-3xl"]}>
            {heroParagraphs.map((line) => (
              <p class="qv-hero-body qv-muted">{line}</p>
            ))}
          </div>
        ) : null}
        <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
          {page.hero?.primaryLabel && page.hero?.primaryUrl ? (
            <a href={page.hero.primaryUrl} class="qv-btn-accent qv-page-hero-btn rounded-xl px-5 py-3 text-sm font-bold uppercase tracking-[0.12em]">
              {page.hero.primaryLabel}
            </a>
          ) : null}
          {page.hero?.secondaryLabel && page.hero?.secondaryUrl ? (
            <a href={page.hero.secondaryUrl} class="qv-btn-soft qv-page-hero-btn rounded-xl px-5 py-3 text-sm font-bold uppercase tracking-[0.12em]">
              {page.hero.secondaryLabel}
            </a>
          ) : null}
        </div>
        {pageHeroMedia.length ? (
          <div class:list={["mt-7", heroImageEdgeToEdge ? "qv-hero-media-edge" : ""]}>
            <img
              src={pageHeroMedia[0].src}
              alt={pageHeroMedia[0].alt}
              class:list={[
                "w-full object-cover",
                heroImageEdgeToEdge
                  ? "max-h-[78vh] border-y border-[rgb(0_217_255_/_0.22)]"
                  : "max-h-[520px] rounded-2xl border border-[rgb(0_217_255_/_0.28)]",
              ]}
              loading="eager"
            />
          </div>
        ) : null}
      </article>
    ) : null}

    <div class:list={isAboutPage ? "qv-about-modules" : ""}>
      <PageSections sections={pageSections} artworks={artworks} posts={posts} projects={projects} themeSectionClass={theme.section} />
    </div>
      </>
    )}
  </section>
  )}
</SiteLayout>
