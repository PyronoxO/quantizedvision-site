---
import SiteLayout from "../layouts/SiteLayout.astro";
import { getMusicTracks } from "../lib/content";

const tracks = await getMusicTracks();

const toEmbedUrl = (trackUrl: string, override?: string) => {
  if (override?.trim()) return override.trim();
  const encoded = encodeURIComponent(trackUrl);
  return `https://w.soundcloud.com/player/?url=${encoded}&color=%2300bcd4&auto_play=false&hide_related=false&show_comments=false&show_user=true&show_reposts=false&show_teaser=true&visual=false`;
};

const pageUrl = "https://quantizedvision.com/music";
const playlistSchema = {
  "@context": "https://schema.org",
  "@type": "MusicPlaylist",
  name: "Quantized Vision SoundCloud Releases",
  url: pageUrl,
  numTracks: tracks.length,
  track: tracks.map((track) => ({
    "@type": "MusicRecording",
    name: track.title,
    byArtist: {
      "@type": "MusicGroup",
      name: track.artist || "Quantized Vision",
    },
    url: track.soundcloudUrl,
  })),
};
---

<SiteLayout
  title="Music | Quantized Vision"
  description="Stream Quantized Vision music releases from SoundCloud, including latest tracks and featured drops."
  canonicalUrl={pageUrl}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(playlistSchema)} />
  </Fragment>

  <section class="dynamic-template mx-auto max-w-6xl space-y-6">
    <header class="qv-panel rounded-2xl p-6 md:p-8">
      <p class="qv-chip inline-flex items-center rounded-full px-3 py-1 text-xs uppercase tracking-[0.18em]">SoundCloud Releases</p>
      <h1 class="mt-4 text-3xl font-extrabold uppercase tracking-[0.03em] md:text-5xl">Music</h1>
      <p class="mt-4 max-w-3xl qv-muted">
        Official Quantized Vision tracks. Stream directly, open on SoundCloud, and follow new drops.
      </p>
    </header>

    {tracks.length ? (
      <div class="grid gap-4 md:grid-cols-2">
        {tracks.map((track) => (
          <article class="qv-panel rounded-2xl p-4 md:p-5">
            <div class="mb-3 flex items-start justify-between gap-3">
              <div>
                <h2 class="text-lg font-bold qv-text md:text-xl">{track.title}</h2>
                <p class="text-sm qv-muted">{track.artist || "Quantized Vision"}</p>
              </div>
              {track.releaseDate ? <time class="text-xs qv-muted">{track.releaseDate}</time> : null}
            </div>
            <iframe
              title={`SoundCloud player for ${track.title}`}
              width="100%"
              height="166"
              scrolling="no"
              frameborder="no"
              allow="autoplay"
              src={toEmbedUrl(track.soundcloudUrl, track.embedUrl)}
            ></iframe>
            <div class="mt-3 flex items-center justify-between gap-3">
              {track.description ? <p class="line-clamp-2 text-sm qv-muted">{track.description}</p> : <span></span>}
              <a class="qv-link text-xs font-bold uppercase tracking-[0.14em]" href={track.soundcloudUrl} target="_blank" rel="noopener noreferrer">
                Open on SoundCloud
              </a>
            </div>
          </article>
        ))}
      </div>
    ) : (
      <div class="qv-panel rounded-2xl p-6">
        <p class="qv-muted">No tracks yet. Add entries in Studio under `Content > Music Tracks`.</p>
      </div>
    )}
  </section>
</SiteLayout>
