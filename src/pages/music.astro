---
import SiteLayout from "../layouts/SiteLayout.astro";
import { getMusicTracks } from "../lib/content";

const tracks = await getMusicTracks();

const toEmbedUrl = (trackUrl: string, override?: string) => {
  const base = override?.trim() || `https://w.soundcloud.com/player/?url=${encodeURIComponent(trackUrl)}`;
  try {
    const url = new URL(base);
    if (!url.hostname.includes("soundcloud.com")) throw new Error("not_soundcloud");
    if (!url.searchParams.get("url")) {
      url.searchParams.set("url", trackUrl);
    }
    url.searchParams.set("color", "#000000");
    url.searchParams.set("auto_play", "false");
    url.searchParams.set("hide_related", "false");
    url.searchParams.set("show_comments", "false");
    url.searchParams.set("show_user", "true");
    url.searchParams.set("show_reposts", "false");
    url.searchParams.set("show_teaser", "true");
    url.searchParams.set("visual", "true");
    return url.toString();
  } catch {
    const encoded = encodeURIComponent(trackUrl);
    return `https://w.soundcloud.com/player/?url=${encoded}&color=%23000000&auto_play=false&hide_related=false&show_comments=false&show_user=true&show_reposts=false&show_teaser=true&visual=true`;
  }
};

const pageUrl = "https://quantizedvision.com/music";
const playlistSchema = {
  "@context": "https://schema.org",
  "@type": "MusicPlaylist",
  name: "Quantized Vision SoundCloud Releases",
  url: pageUrl,
  numTracks: tracks.length,
  track: tracks.map((track) => ({
    "@type": "MusicRecording",
    name: track.title,
    byArtist: {
      "@type": "MusicGroup",
      name: track.artist || "Quantized Vision",
    },
    url: track.soundcloudUrl,
  })),
};
---

<SiteLayout
  title="Music Production | Quantized Vision"
  description="Original music releases, music videos, and AI-assisted production work from Quantized Vision, including SoundCloud tracks and visual direction context."
  canonicalUrl={pageUrl}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(playlistSchema)} />
  </Fragment>

  <section class="dynamic-template mx-auto max-w-6xl space-y-6">
    <header class="qv-panel rounded-2xl p-6 md:p-8">
      <h1 class="text-3xl font-extrabold uppercase tracking-[0.03em] md:text-5xl">Music Production</h1>
      <p class="mt-4 max-w-3xl qv-muted">
        Original music releases and music videos from Quantized Vision, combining music production with AI-assisted visual direction.
      </p>
    </header>

    {tracks.length ? (
      <div class="grid gap-4 md:grid-cols-2">
        {tracks.map((track) => (
          <article class="qv-panel rounded-2xl p-4 md:p-5">
            <div class="mb-3 flex items-start justify-between gap-3">
              <div>
                <h2 class="text-lg font-bold qv-text md:text-xl">{track.title}</h2>
                <p class="text-sm qv-muted">{track.artist || "Quantized Vision"}</p>
              </div>
              {track.releaseDate ? <time class="text-xs qv-muted">{track.releaseDate}</time> : null}
            </div>
            <iframe
              title={`SoundCloud player for ${track.title}`}
              width="100%"
              height="320"
              scrolling="no"
              frameborder="no"
              allow="autoplay"
              src={toEmbedUrl(track.soundcloudUrl, track.embedUrl)}
            ></iframe>
            <div class="mt-3 flex items-center justify-between gap-3">
              {track.description ? <p class="line-clamp-2 text-sm qv-muted">{track.description}</p> : <span></span>}
              <a class="qv-link text-xs font-bold uppercase tracking-[0.14em]" href={track.soundcloudUrl} target="_blank" rel="noopener noreferrer">
                Open on SoundCloud
              </a>
            </div>
          </article>
        ))}
      </div>
    ) : (
      <div class="qv-panel rounded-2xl p-6">
        <p class="qv-muted">No tracks yet. Add entries in Studio under `Content > Music Tracks`.</p>
      </div>
    )}
  </section>
</SiteLayout>
