---
import "../styles/global.css";
import { getSiteSettings } from "../lib/content";
import type { HomeDesignSettings, NavigationItem } from "../types/content";

interface Props {
  title: string;
  description?: string;
  author?: string;
  canonicalUrl?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogImageType?: string;
  ogImageWidth?: string | number;
  ogImageHeight?: string | number;
  ogImageAlt?: string;
  ogType?: "website" | "article";
  noIndex?: boolean;
}

const {
  title,
  description = "Quantized Vision digital portfolio.",
  canonicalUrl,
  ogTitle,
  ogDescription,
  ogImage,
  ogImageType,
  ogImageWidth,
  ogImageHeight,
  ogImageAlt,
  ogType = "website",
  noIndex = false,
  author = "Quantized Vision",
} = Astro.props;
const preview = Astro.url.searchParams.get("preview") === "1";
const siteSettings = await getSiteSettings({ preview });

const fontStacks: Record<string, string> = {
  orbitron: "'Orbitron', 'Rajdhani', 'Arial Narrow', sans-serif",
  "space-grotesk": "'Space Grotesk', 'Sora', sans-serif",
  sora: "'Sora', 'Space Grotesk', sans-serif",
  "bebas-neue": "'Bebas Neue', 'Oswald', 'Arial Narrow', sans-serif",
  rajdhani: "'Rajdhani', 'Space Grotesk', sans-serif",
  manrope: "'Manrope', 'Inter', sans-serif",
};

const fallbackDesign: HomeDesignSettings = {
  headingFont: "manrope",
  bodyFont: "manrope",
  uiFont: "manrope",
  h1Size: "clamp(4.6rem, 11vw, 9.2rem)",
  h2Size: "clamp(1.8rem, 4.6vw, 3rem)",
  h3Size: "clamp(1.25rem, 2.6vw, 1.9rem)",
  h4Size: "clamp(1.1rem, 1.9vw, 1.4rem)",
  h5Size: "clamp(0.95rem, 1.4vw, 1.2rem)",
  h6Size: "clamp(0.88rem, 1.2vw, 1.04rem)",
  bodySize: "1rem",
  textColor: "#F5F5F7",
  mutedColor: "#9CA3AF",
  accentColor: "#00D9FF",
  linkColor: "#CFE6FF",
  sectionDividerOpacity: 0.08,
  seamLeftTintOpacity: 0.11,
  seamRightTintOpacity: 0.14,
  seamTopEdgeOpacity: 0.16,
  seamBottomEdgeOpacity: 0.14,
  aboutHeroGap: "3.4rem",
  aboutFirstModuleHeadingSize: "2.05rem",
  aboutFirstModuleBodySize: "1.16rem",
};

const design = { ...fallbackDesign, ...(siteSettings?.design || {}) };
const headingFontStack = fontStacks[design.headingFont || "orbitron"] || fontStacks.orbitron;
const bodyFontStack = fontStacks[design.bodyFont || "space-grotesk"] || fontStacks["space-grotesk"];
const uiFontStack = fontStacks[design.uiFont || "rajdhani"] || fontStacks.rajdhani;
const toCssSize = (value: number | string | undefined, fallback: string) => {
  if (typeof value === "number" && Number.isFinite(value)) return `${value}rem`;
  if (typeof value === "string" && value.trim()) {
    const trimmed = value.trim();
    const numeric = Number(trimmed);
    if (Number.isFinite(numeric)) return `${numeric}rem`;
    return trimmed;
  }
  return fallback;
};
const toCssOpacity = (value: number | string | undefined, fallback: string) => {
  if (typeof value === "number" && Number.isFinite(value)) return String(Math.max(0, Math.min(1, value)));
  if (typeof value === "string" && value.trim()) {
    const numeric = Number(value.trim());
    if (Number.isFinite(numeric)) return String(Math.max(0, Math.min(1, numeric)));
  }
  return fallback;
};
const resolvedTypeScale = {
  h1: toCssSize(design.h1Size, "clamp(4.6rem, 11vw, 9.2rem)"),
  h2: toCssSize(design.h2Size, "clamp(1.8rem, 4.6vw, 3rem)"),
  h3: toCssSize(design.h3Size, "clamp(1.25rem, 2.6vw, 1.9rem)"),
  h4: toCssSize(design.h4Size, "clamp(1.1rem, 1.9vw, 1.4rem)"),
  h5: toCssSize(design.h5Size, "clamp(0.95rem, 1.4vw, 1.2rem)"),
  h6: toCssSize(design.h6Size, "clamp(0.88rem, 1.2vw, 1.04rem)"),
  body: toCssSize(design.bodySize, "1rem"),
};

const fallbackNavItems = [
  { href: "/", label: "Home" },
];

const mappedNav = (siteSettings?.navigation || [])
  .map((item: NavigationItem) => {
    const label = (item.label || "").trim();
    if (!label) return null;
    const href = item.url?.trim()
      ? item.url.trim()
      : item.page
        ? item.page.isHome || item.page.slug === "home"
          ? "/"
          : `/${(item.page.slug || "").replace(/^\/+/, "")}`
        : "";
    if (!href) return null;
    return { href, label, openInNewTab: Boolean(item.openInNewTab), external: /^https?:\/\//i.test(href) };
  })
  .filter(Boolean) as { href: string; label: string; openInNewTab: boolean; external: boolean }[];

const navItems = mappedNav.length ? mappedNav : fallbackNavItems.map((item) => ({ ...item, openInNewTab: false, external: false }));

const currentPath = Astro.url.pathname;
const isHomeRoute = currentPath === "/";
const publicSiteUrl = ((import.meta as any).env?.PUBLIC_SITE_URL as string | undefined)?.trim() || Astro.url.origin;
const googleSiteVerification = ((import.meta as any).env?.PUBLIC_GOOGLE_SITE_VERIFICATION as string | undefined)?.trim();
const bingSiteVerification =
  ((import.meta as any).env?.PUBLIC_BING_SITE_VERIFICATION as string | undefined)?.trim() ||
  "00E07BE594A3775B023980AFA00D66DB";
const plausibleDomain = ((import.meta as any).env?.PUBLIC_PLAUSIBLE_DOMAIN as string | undefined)?.trim();
const plausibleScriptSrc =
  ((import.meta as any).env?.PUBLIC_PLAUSIBLE_SCRIPT_SRC as string | undefined)?.trim() ||
  "https://plausible.io/js/script.js";
const resolvedCanonicalUrl = canonicalUrl
  ? new URL(canonicalUrl, Astro.url.origin).toString()
  : new URL(Astro.url.pathname, publicSiteUrl).toString();
const resolvedOgImage = ogImage ? new URL(ogImage, Astro.url.origin).toString() : undefined;
const resolvedOgImageWidth = ogImageWidth ? String(ogImageWidth) : undefined;
const resolvedOgImageHeight = ogImageHeight ? String(ogImageHeight) : undefined;
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Quantized Vision",
  url: publicSiteUrl,
  logo: `${publicSiteUrl.replace(/\/+$/, "")}/img/works/logo-watermark.png`,
  sameAs: [
    "https://www.tiktok.com/@quantizedvision",
    "https://www.instagram.com/quantizedvision",
    "https://www.youtube.com/@quantizedvision",
    "https://www.facebook.com/quantizedvision",
  ],
};
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Quantized Vision",
  url: publicSiteUrl,
  inLanguage: "en",
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    {googleSiteVerification ? <meta name="google-site-verification" content={googleSiteVerification} /> : null}
    {bingSiteVerification ? <meta name="msvalidate.01" content={bingSiteVerification} /> : null}
    {noIndex ? (
      <meta name="robots" content="noindex,nofollow" />
    ) : (
      <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    )}
    {resolvedCanonicalUrl ? <link rel="canonical" href={resolvedCanonicalUrl} /> : null}
    <link rel="alternate" type="application/rss+xml" title="Quantized Vision Posts RSS" href={`${publicSiteUrl.replace(/\/+$/, "")}/rss.xml`} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Quantized Vision" />
    <meta property="og:title" content={ogTitle || title} />
    <meta property="og:description" content={ogDescription || description} />
    {resolvedCanonicalUrl ? <meta property="og:url" content={resolvedCanonicalUrl} /> : null}
    {resolvedOgImage ? <meta property="og:image" content={resolvedOgImage} /> : null}
    {resolvedOgImage ? <meta property="og:image:url" content={resolvedOgImage} /> : null}
    {resolvedOgImage ? <meta property="og:image:secure_url" content={resolvedOgImage} /> : null}
    {ogImageType ? <meta property="og:image:type" content={ogImageType} /> : null}
    {resolvedOgImageWidth ? <meta property="og:image:width" content={resolvedOgImageWidth} /> : null}
    {resolvedOgImageHeight ? <meta property="og:image:height" content={resolvedOgImageHeight} /> : null}
    {resolvedOgImage ? <meta property="og:image:alt" content={ogImageAlt || ogTitle || title} /> : null}
    <meta name="twitter:card" content="summary_large_image" />
    {resolvedCanonicalUrl ? <meta name="twitter:url" content={resolvedCanonicalUrl} /> : null}
    <meta name="twitter:title" content={ogTitle || title} />
    <meta name="twitter:description" content={ogDescription || description} />
    {resolvedOgImage ? <meta name="twitter:image" content={resolvedOgImage} /> : null}
    <meta name="theme-color" content="#0a1224" />
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    {plausibleDomain ? (
      <>
        <script defer data-domain={plausibleDomain} src={plausibleScriptSrc}></script>
        <script is:inline>{`window.qvTrack = function(eventName, props){ if (typeof window.plausible === "function") { window.plausible(eventName, props ? { props } : undefined); } };`}</script>
      </>
    ) : null}
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Manrope:wght@400;600;700;800&family=Orbitron:wght@500;700;800&family=Rajdhani:wght@500;600;700&family=Sora:wght@400;600;700;800&family=Space+Grotesk:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <slot name="head" />
  </head>
  <body
    class="qv-shell min-h-screen bg-[var(--qv-base)] text-[var(--qv-text)]"
    style={`
      --qv-font-display:${headingFontStack};
      --qv-font-body:${bodyFontStack};
      --qv-font-ui:${uiFontStack};
      --qv-h1-size:${resolvedTypeScale.h1};
      --qv-h2-size:${resolvedTypeScale.h2};
      --qv-h3-size:${resolvedTypeScale.h3};
      --qv-h4-size:${resolvedTypeScale.h4};
      --qv-h5-size:${resolvedTypeScale.h5};
      --qv-h6-size:${resolvedTypeScale.h6};
      --qv-body-size:${resolvedTypeScale.body};
      --qv-text:${design.textColor};
      --qv-muted:${design.mutedColor};
      --qv-accent:${design.accentColor};
      --qv-link:${design.linkColor};
      --qv-section-divider-opacity:${toCssOpacity(design.sectionDividerOpacity, "0.08")};
      --qv-seam-left-tint-opacity:${toCssOpacity(design.seamLeftTintOpacity, "0.11")};
      --qv-seam-right-tint-opacity:${toCssOpacity(design.seamRightTintOpacity, "0.14")};
      --qv-seam-top-edge-opacity:${toCssOpacity(design.seamTopEdgeOpacity, "0.16")};
      --qv-seam-bottom-edge-opacity:${toCssOpacity(design.seamBottomEdgeOpacity, "0.14")};
      --qv-about-hero-gap:${toCssSize(design.aboutHeroGap, "3.4rem")};
      --qv-about-first-module-heading-size:${toCssSize(design.aboutFirstModuleHeadingSize, "2.05rem")};
      --qv-about-first-module-body-size:${toCssSize(design.aboutFirstModuleBodySize, "1.16rem")};
    `}
  >
    <div class="qv-bg"></div>
    <div class="qv-anim-orb is-cyan"></div>
    <div class="qv-anim-orb is-orange"></div>
    <div class="qv-anim-orb is-magenta"></div>
    <header class="fixed left-0 right-0 top-0 z-30 border-b border-[rgb(0_217_255_/_0.12)] bg-[#0d0d1a]/96 backdrop-blur-xl">
      <nav class="mx-auto grid w-full max-w-[1440px] grid-cols-[auto_1fr_auto] items-center gap-4 px-4 py-4 md:px-6 md:py-5 lg:px-12">
        <a href="/" class="inline-flex items-center gap-2">
          <img src="/img/works/logo-watermark.png" alt="" class="h-9 w-9 object-contain" />
        </a>
        <span></span>
        <div class="hidden flex-wrap justify-end gap-8 lg:flex text-[clamp(0.92rem,1.1vw,1.02rem)]">
          {navItems.map((item) => (
            <a
              href={item.href}
              target={item.openInNewTab ? "_blank" : undefined}
              rel={item.openInNewTab ? "noopener noreferrer" : undefined}
              data-astro-prefetch={!item.external ? "tap" : undefined}
              class:list={[
                "qv-nav-link px-0 py-1",
                !item.external && currentPath === item.href ? "is-active" : "",
              ]}
            >
              {item.label}
            </a>
          ))}
        </div>
        <details class="qv-mobile-nav relative justify-self-end lg:hidden">
          <summary class="qv-mobile-summary qv-btn-soft inline-flex min-h-[44px] cursor-pointer list-none items-center rounded-lg px-3 py-2 text-sm font-bold uppercase tracking-[0.08em]">
            Menu
          </summary>
          <div class="qv-mobile-menu-panel fixed left-3 right-3 top-[4.6rem] z-[120] rounded-xl border border-[rgb(0_217_255_/_0.25)] bg-[#091226]/95 p-2 shadow-[0_16px_36px_rgba(0,0,0,0.42)] backdrop-blur-xl">
            {navItems.map((item) => (
              <a
                href={item.href}
                target={item.openInNewTab ? "_blank" : undefined}
                rel={item.openInNewTab ? "noopener noreferrer" : undefined}
                data-astro-prefetch={!item.external ? "tap" : undefined}
                data-mobile-internal={!item.external && !item.openInNewTab ? "true" : "false"}
                class:list={[
                  "qv-mobile-nav-link block rounded-md px-3 py-2.5 text-sm font-semibold uppercase tracking-[0.08em] qv-muted hover:bg-[rgb(0_217_255_/_0.08)] hover:text-[var(--qv-text)]",
                  !item.external && currentPath === item.href ? "bg-[rgb(0_217_255_/_0.1)] text-[var(--qv-text)]" : "",
                ]}
              >
                {item.label}
              </a>
            ))}
          </div>
        </details>
      </nav>
    </header>
    <main
      class:list={[
        "w-full pt-24 md:pb-12",
        isHomeRoute
          ? "px-0 pb-0"
          : "mx-auto max-w-[1440px] px-4 pb-10 sm:px-6 lg:px-12",
      ]}
    >
      <slot />
    </main>
    <footer
      class:list={[
        "w-full px-4 py-10 text-center text-sm text-[var(--qv-muted)]",
        isHomeRoute ? "mt-0" : "mx-auto mt-10 max-w-[1440px] border-t border-[rgb(0_217_255_/_0.16)]",
      ]}
    >
      <p>© {new Date().getFullYear()} Quantized Vision. All rights reserved.</p>
    </footer>
    <script is:inline>
      (() => {
        const menus = Array.from(document.querySelectorAll(".qv-mobile-nav"));
        if (!menus.length) return;

        const closeAll = () => {
          menus.forEach((menu) => {
            if (menu instanceof HTMLDetailsElement) menu.open = false;
          });
        };
        const prefetched = new Set();
        const prefetchRoute = (href) => {
          if (!href || prefetched.has(href)) return;
          prefetched.add(href);
          const prefetchEl = document.createElement("link");
          prefetchEl.rel = "prefetch";
          prefetchEl.as = "document";
          prefetchEl.href = href;
          document.head.appendChild(prefetchEl);
          fetch(href, { method: "GET", credentials: "same-origin" }).catch(() => {});
        };

        document.addEventListener("click", (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;
          const insideMenu = menus.some((menu) => menu.contains(target));
          if (!insideMenu) closeAll();
        });

        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape") closeAll();
        });

        menus.forEach((menu) => {
          if (menu instanceof HTMLDetailsElement) {
            menu.addEventListener("toggle", () => {
              if (!menu.open) return;
              menu.querySelectorAll("a[data-mobile-internal='true']").forEach((link) => {
                if (link instanceof HTMLAnchorElement) prefetchRoute(link.href);
              });
            });
          }
          menu.querySelectorAll("a[href]").forEach((link) => {
            link.addEventListener("click", () => {
              if (menu instanceof HTMLDetailsElement) menu.open = false;
            });
          });
          menu.querySelectorAll("a[data-mobile-internal='true']").forEach((link) => {
            if (!(link instanceof HTMLAnchorElement)) return;
            link.addEventListener(
              "pointerdown",
              (event) => {
                if (event.button !== 0) return;
                event.preventDefault();
                if (menu instanceof HTMLDetailsElement) menu.open = false;
                link.classList.add("is-loading");
                prefetchRoute(link.href);
                requestAnimationFrame(() => {
                  window.location.assign(link.href);
                });
              },
              { passive: false },
            );
          });
        });
      })();
    </script>
    {plausibleDomain ? (
      <script is:inline>{`
        document.addEventListener("click", (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;
          const link = target.closest("a[href]");
          if (!(link instanceof HTMLAnchorElement)) return;
          const href = link.href;
          if (!href) return;
          let external = false;
          try {
            external = new URL(href).origin !== window.location.origin;
          } catch {
            return;
          }
          if (!external) return;
          if (typeof window.qvTrack === "function") {
            window.qvTrack("outbound_link_click", { href });
          }
        });
      `}</script>
    ) : null}
  </body>
</html>
